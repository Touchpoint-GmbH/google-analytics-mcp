# =============================================================================
# GA4 MCP Server — environment configuration (Dokploy)
# Copy these into the Dokploy "Environment" tab and fill in the values.
#
# Auth model: personal Google login via OAuth 2.0. Each user signs in through
# the MCP connector with their own Google account, and every request runs with
# that user's Google Analytics permissions. The account must have been granted
# access to the relevant GA4 properties beforehand.
# =============================================================================

# --- OAuth 2.0 client (required) ---------------------------------------------
# From your GCP project: APIs & Services > Credentials > OAuth 2.0 Client ID
# (type "Web application"). Enable the Analytics Admin API and Analytics Data
# API in the same project.
#
# In the OAuth client, add this Authorized redirect URI:
#   <ANALYTICS_MCP_BASE_URL>/auth/callback
ANALYTICS_MCP_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
ANALYTICS_MCP_OAUTH_CLIENT_SECRET=your-client-secret

# Public HTTPS base URL where this server is reachable (no trailing slash).
# Used to build the OAuth callback and discovery metadata.
ANALYTICS_MCP_BASE_URL=https://ga4-mcp.touchpoint.agency

# --- Server binding (defaults are fine for Dokploy) ---------------------------
HOST=0.0.0.0
PORT=8000
